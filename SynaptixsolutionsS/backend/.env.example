# ============================================
# Synaptix Backend - Environment Variables
# ============================================

# MongoDB Atlas Connection String
# Get this from: mongodb.com → Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/synaptix?retryWrites=true&w=majority

# JWT Secret Key (generate any random long string)
JWT_SECRET=synaptix-secret-key-2026-change-this-to-something-random

# Admin Dashboard Password
ADMIN_PASSWORD=Abhijit@2
# Frontend URL (for CORS - your Netlify or custom domain)
# Use * for development, or your actual domain for production
FRONTEND_URL=https://your-frontend-url.netlify.app

# Node Environment
NODE_ENV=production
